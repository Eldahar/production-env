# ══════════════════════════════════════════════════════════
# Production Environment — .env.prod
# ══════════════════════════════════════════════════════════
# Másold .env.prod-ként és töltsd ki a valódi értékekkel.
# Generáláshoz: ./scripts/generate-secrets.sh
# SOHA ne commit-old git-be!
# ══════════════════════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_PASSWORD=CHANGE_ME

# ── Symfony ──
APP_SECRET=CHANGE_ME
APP_ENV=prod

# ── Database ──
# FONTOS: Docker env_file NEM interpolál változókat!
# A jelszót közvetlenül ide írd be (ugyanaz mint POSTGRES_PASSWORD fentebb).
DATABASE_URL=postgresql://app:CHANGE_ME@postgres:5432/pm_central?serverVersion=18&charset=utf8
TENANT_DATABASE_URL=postgresql://app:CHANGE_ME@postgres:5432/pm_tenant_default?serverVersion=18&charset=utf8

# ── JWT ──
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGE_ME

# ── Encryption (integration credentials) ──
ENCRYPTION_KEY=CHANGE_ME

# ── URLs ──
DEFAULT_URI=https://pm.maturin.hu
FRONTEND_URL=https://pm.maturin.hu
INTERNAL_API_BASE_URL=http://api:8080

# ── OAuth2 (service-to-service auth) ──
OAUTH2_ENCRYPTION_KEY=CHANGE_ME

# ── Messenger (Symfony) ──
MESSENGER_TRANSPORT_DSN=doctrine://central?auto_setup=true
# API uses doctrine transport for failed messages (direct central DB access).
# Workers use http-failed:// transport (relays to API via HTTP).
FAILED_TRANSPORT_DSN=doctrine://central?queue_name=failed

# ── Mail (Resend — https://resend.com) ──
MAILER_DSN=resend+api://re_XXXXX@default

# ── AI Service ──
ANTHROPIC_API_KEY=sk-ant-XXXXX

# ── Jira Integration (opcionális) ──
#JIRA_INSTANCE_URL=
#JIRA_API_TOKEN=
#JIRA_USER_EMAIL=
